rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function ownUser(userId) { return signedIn() && request.auth.uid == userId; }
    function joinedKameti(kametiId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/joinedKametis/$(kametiId))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/joinedKametis/$(kametiId)).data.status == 'active';
    }
    function kametiDoc(kametiId) {
      return get(/databases/$(database)/documents/kametis/$(kametiId));
    }
    function kametiDocExists(kametiId) {
      return exists(/databases/$(database)/documents/kametis/$(kametiId));
    }
    function kametiOwnerByDoc(kametiId) {
      return signedIn()
        && kametiDocExists(kametiId)
        && kametiDoc(kametiId).data.ownerUserId == request.auth.uid;
    }
    function kametiMemberByArray(kametiId) {
      return signedIn()
        && kametiDocExists(kametiId)
        && kametiDoc(kametiId).data.keys().hasAny(['memberUserIds'])
        && request.auth.uid in kametiDoc(kametiId).data.memberUserIds;
    }
    function kametiMember(kametiId) {
      return joinedKameti(kametiId)
        || kametiOwnerByDoc(kametiId)
        || kametiMemberByArray(kametiId)
        || (signedIn() && exists(/databases/$(database)/documents/kametis/$(kametiId)/members/$(request.auth.uid)));
    }
    function kametiManager(kametiId) {
      return (signedIn()
          && exists(/databases/$(database)/documents/kametis/$(kametiId))
          && get(/databases/$(database)/documents/kametis/$(kametiId)).data.ownerUserId == request.auth.uid)
        || (signedIn()
          && exists(/databases/$(database)/documents/kametis/$(kametiId)/members/$(request.auth.uid))
          && get(/databases/$(database)/documents/kametis/$(kametiId)/members/$(request.auth.uid)).data.role in ['organizer', 'coOrganizer'])
        || (joinedKameti(kametiId)
          && get(/databases/$(database)/documents/users/$(request.auth.uid)/joinedKametis/$(kametiId)).data.role in ['organizer', 'coOrganizer']);
    }
    function notBlocked(kametiId) {
      return kametiMember(kametiId)
        && (!exists(/databases/$(database)/documents/kametis/$(kametiId)/members/$(request.auth.uid))
          || get(/databases/$(database)/documents/kametis/$(kametiId)/members/$(request.auth.uid)).data.status != 'blocked');
    }

    match /users/{userId} {
      allow read, update: if ownUser(userId);
      allow create: if signedIn() && request.auth.uid == userId;
      match /notifications/{notificationId} {
        allow read, update, delete: if ownUser(userId);
        allow create: if ownUser(userId);
      }
      match /joinedKametis/{kametiId} {
        allow read: if ownUser(userId);
        allow write: if ownUser(userId) || kametiManager(kametiId);
      }
      match /securityLogs/{logId} {
        allow read: if ownUser(userId);
        allow create: if signedIn();
        allow update, delete: if false;
      }
      match /trustScores/{scoreId} {
        allow read: if ownUser(userId);
        allow write: if false;
      }
      match /settings/{settingId} {
        allow read, write: if ownUser(userId);
      }
    }

    match /publicUserProfiles/{userId} {
      allow read: if signedIn();
      allow create, update: if ownUser(userId);
      allow delete: if false;
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /kametis/{kametiId} {
      allow read: if joinedKameti(kametiId)
        || (signedIn() && exists(/databases/$(database)/documents/kametis/$(kametiId)/members/$(request.auth.uid)))
        || (signedIn() && resource.data.ownerUserId == request.auth.uid)
        || (signedIn()
          && resource.data.keys().hasAny(['memberUserIds'])
          && request.auth.uid in resource.data.memberUserIds);
      allow create: if signedIn() && request.resource.data.ownerUserId == request.auth.uid;
      allow update, delete: if kametiManager(kametiId);

      match /members/{memberId} {
        allow read: if kametiMember(kametiId);
        allow create: if kametiManager(kametiId) || (signedIn() && request.auth.uid == memberId);
        allow update: if kametiManager(kametiId) || (signedIn() && request.auth.uid == memberId && !('role' in request.resource.data.diff(resource.data).changedKeys()));
        allow delete: if kametiManager(kametiId);
      }
      match /cycles/{cycleId} {
        allow read: if kametiMember(kametiId);
        allow write: if kametiManager(kametiId);
        match /payments/{paymentId} {
          allow read: if kametiMember(kametiId);
          allow create: if kametiManager(kametiId);
          allow update: if kametiManager(kametiId)
            || (notBlocked(kametiId)
              && request.resource.data.memberUserId == request.auth.uid
              && request.resource.data.paymentStatus in ['proofSubmitted', 'pendingApproval']);
        }
      }
      match /biddingSessions/{sessionId} {
        allow read: if kametiMember(kametiId);
        allow create, update: if kametiManager(kametiId);
        match /bids/{bidId} {
          allow read: if kametiMember(kametiId);
          allow create, update: if kametiManager(kametiId) || (notBlocked(kametiId) && request.resource.data.userId == request.auth.uid);
        }
      }
      match /receiverAllocations/{allocationId} {
        allow read: if kametiMember(kametiId);
        allow write: if kametiManager(kametiId);
      }
      match /ledgerEntries/{entryId} {
        allow read: if kametiMember(kametiId);
        allow write: if kametiManager(kametiId);
      }
      match /luckyDraws/{drawId} {
        allow read: if kametiMember(kametiId);
        allow write: if kametiManager(kametiId);
      }
      match /reports/{reportId} {
        allow read: if kametiManager(kametiId)
          || (kametiMember(kametiId) && resource.data.visibility == 'sharedWithMembers');
        allow write: if kametiManager(kametiId);
      }
      match /auditLogs/{auditLogId} {
        allow read: if kametiManager(kametiId);
        allow create: if signedIn();
        allow update, delete: if false;
      }
      match /disputes/{disputeId} {
        allow read: if kametiManager(kametiId)
          || resource.data.createdBy == request.auth.uid
          || resource.data.againstUserId == request.auth.uid;
        allow create: if notBlocked(kametiId);
        allow update: if kametiManager(kametiId)
          || resource.data.createdBy == request.auth.uid
          || resource.data.againstUserId == request.auth.uid;
        allow delete: if false;
        match /comments/{commentId} {
          allow read: if kametiMember(kametiId);
          allow create: if notBlocked(kametiId);
          allow update, delete: if false;
        }
      }
      match /trustScores/{scoreId} {
        allow read: if kametiManager(kametiId);
        allow write: if false;
      }
      match /userReports/{reportId} {
        allow read, update: if kametiManager(kametiId);
        allow create: if notBlocked(kametiId);
        allow delete: if false;
      }
    }

    match /kametiInvites/{inviteId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
    }
    match /deletionRequests/{requestId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
