rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function kametiMember(kametiId) {
      return signedIn() && firestore.exists(/databases/(default)/documents/kametis/$(kametiId)/members/$(request.auth.uid));
    }
    function kametiManager(kametiId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/kametis/$(kametiId)/members/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/kametis/$(kametiId)/members/$(request.auth.uid)).data.role in ['organizer', 'coOrganizer'];
    }

    match /users/{userId}/{fileName} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
    match /kametis/{kametiId}/payments/{cycleId}/{memberId}/{fileName} {
      allow read: if kametiMember(kametiId);
      allow write: if kametiManager(kametiId) || (signedIn() && request.auth.uid == memberId);
    }
    match /kametis/{kametiId}/payouts/{allocationId}/{fileName} {
      allow read: if kametiMember(kametiId);
      allow write: if kametiManager(kametiId);
    }
    match /kametis/{kametiId}/disputes/{disputeId}/{fileName} {
      allow read: if kametiMember(kametiId);
      allow write: if kametiMember(kametiId);
    }
    match /kametis/{kametiId}/reports/{reportId}/{fileName} {
      allow read: if kametiMember(kametiId);
      allow write: if kametiManager(kametiId);
    }
  }
}
